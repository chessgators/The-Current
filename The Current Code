function FishingGame({ onClose }) {
  const [phase, setPhase] = useState('idle');
  const [lineLen, setLineLen] = useState(0);
  const [splash, setSplash] = useState(false);
  const [catchItem, setCatchItem] = useState(null);
  const [catchCount, setCatchCount] = useState(0);
  const intervalRef = useRef(null);

  const handleClick = useCallback(() => {
    if (catchItem) return;
    if (phase === 'idle') {
      setPhase('casting');
      setLineLen(0);
      let l = 0;
      const target = 55 + Math.random() * 38;
      intervalRef.current = setInterval(() => {
        l += 3.8;
        setLineLen(Math.min(l, target));
        if (l >= target) {
          clearInterval(intervalRef.current);
          setSplash(true);
          setTimeout(() => setSplash(false), 700);
        }
      }, 18);
    } else if (phase === 'casting') {
      clearInterval(intervalRef.current);
      setPhase('reeling');
      let l = lineLen;
      intervalRef.current = setInterval(() => {
        l -= 4.5;
        setLineLen(Math.max(0, l));
        if (l <= 0) {
          clearInterval(intervalRef.current);
          setSplash(true);
          setTimeout(() => {
            setSplash(false);
            setCatchItem(pickItem());
            setCatchCount(n => n + 1);
            setPhase('idle');
            setLineLen(0);
          }, 480);
        }
      }, 16);
    }
  }, [phase, catchItem, lineLen]);

  useEffect(() => () => clearInterval(intervalRef.current), []);

  return (
    <>
      <style>{`
        @keyframes aura-pulse { 0%,100%{transform:scale(1);opacity:0.7} 50%{transform:scale(1.18);opacity:1} }
        .fg-root { position:fixed;inset:0;z-index:200;background:#020d18;display:flex;flex-direction:column;overflow:hidden;font-family:'DM Mono',monospace;color:#e8f4f8; }
        .fg-header { display:flex;align-items:center;justify-content:space-between;padding:13px 22px;border-bottom:1px solid rgba(0,212,255,0.18);background:rgba(2,13,24,0.94);backdrop-filter:blur(10px);flex-shrink:0;gap:12px; }
        .fg-title { font-family:'Cormorant Garamond',Georgia,serif;font-size:19px;font-weight:300;letter-spacing:0.2em;text-transform:uppercase;color:#e8f4f8;white-space:nowrap; }
        .fg-title span { color:#00d4ff; }
        .fg-close { background:none;border:1px solid rgba(0,212,255,0.3);color:#a8ccd8;font-family:'DM Mono',monospace;font-size:8px;letter-spacing:0.18em;text-transform:uppercase;padding:6px 14px;cursor:pointer;transition:all 0.15s;white-space:nowrap;flex-shrink:0; }
        .fg-close:hover { border-color:#00d4ff;color:#00d4ff; }
        .fg-scene { flex:1;position:relative;cursor:pointer;overflow:hidden;min-height:0; }
        .fg-legend { display:flex;gap:16px;align-items:center;justify-content:center;padding:9px 20px;border-top:1px solid rgba(0,212,255,0.12);background:rgba(2,13,24,0.92);flex-wrap:wrap;flex-shrink:0; }
        .fg-legend-item { display:flex;align-items:center;gap:5px;font-size:8px;letter-spacing:0.14em;text-transform:uppercase;color:#6a9db0; }
        .fg-dot { width:8px;height:8px;border-radius:50%;flex-shrink:0; }
      `}</style>
      <div className="fg-root">
        <div className="fg-header">
          <div className="fg-title">The <span>Current</span> — Deep Sea Market</div>
          {catchCount > 0 && (
            <div style={{ fontSize:9, letterSpacing:'0.14em', textTransform:'uppercase', color:'#00d4ff', flexShrink:0 }}>
              {catchCount} caught
            </div>
          )}
          <button className="fg-close" onClick={onClose}>← Dashboard</button>
        </div>

        <div className="fg-scene" onClick={handleClick}>
          <BoatScene phase={phase} lineLen={lineLen} splash={splash} />
          {catchItem && <CatchCard item={catchItem} onDismiss={() => setCatchItem(null)} />}
        </div>

        <div className="fg-legend">
          {Object.entries(RARITY).map(([key, r]) => (
            <div key={key} className="fg-legend-item">
              <div className="fg-dot" style={{
                background: key === 'common' ? '#a8ccd8' : r.color,
                boxShadow: r.glow ? `0 0 7px 2px ${r.color}99` : 'none',
              }}/>
              {r.label}
            </div>
          ))}
          <div style={{ fontSize:7.5, color:'#3d6275', letterSpacing:'0.1em', marginLeft:6 }}>
            Higher price = rarer catch
          </div>
        </div>
      </div>
    </>
  );
}

