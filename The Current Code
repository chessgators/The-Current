  const [showRDrop, setShowRDrop]  = useState(false);
  const [regionHi, setRegionHi]    = useState(-1);
  const regionInputRef             = useRef(null);
  const regionDropRef              = useRef(null);

  const [query, setQuery]          = useState('');
  const [showSug, setShowSug]      = useState(false);
  const [hiIdx, setHiIdx]          = useState(-1);
  const [commodity, setCommodity]  = useState(null);
  const [forecast, setForecast]    = useState(null);
  const [loading, setLoading]      = useState(false);
  const [error, setError]          = useState(null);
  const [notFound, setNotFound]    = useState(null);
  const inputRef                   = useRef(null);
  const sugRef                     = useRef(null);

  const [noiseOffset, setNoiseOffset] = useState(0);
  const [livePrice, setLivePrice]     = useState(null);
  const [prevPrice, setPrevPrice]     = useState(null);
  const [flashClass, setFlashClass]   = useState('');

  useEffect(() => { document.body.className = lang==='zh' ? 'zh' : ''; }, [lang]);

  useEffect(() => {
    const id = setInterval(() => setSeaData(p=>({...p,stability:Math.max(0.1,Math.min(1,p.stability+(Math.random()-0.5)*0.02))})), 4000);
    return () => clearInterval(id);
  }, []);

  useEffect(() => {
    if (!commodity) return;
    const id = setInterval(() => setNoiseOffset((Math.random()-0.48)*20), 3000);
    return () => clearInterval(id);
  }, [commodity]);

  useEffect(() => {
    if (!commodity) return;
    const r = calcPrice(commodity, seaData, noiseOffset);
    setPrevPrice(livePrice); setLivePrice(r.currentPrice);
  }, [noiseOffset, seaData, commodity]); // eslint-disable-line

  useEffect(() => {
    if (prevPrice===null || livePrice===null) return;
    setFlashClass(livePrice > prevPrice ? 'flash-up' : 'flash-dn');
    const id = setTimeout(() => setFlashClass(''), 500);
    return () => clearTimeout(id);
  }, [livePrice]); // eslint-disable-line

  useEffect(() => {
    if (!commodity) return;
    setForecast(calcForecast(commodity, seaData));
  }, [seaData, commodity]); // eslint-disable-line

  useEffect(() => {
    const h = (e) => {
      if (regionDropRef.current && !regionDropRef.current.contains(e.target) && regionInputRef.current && !regionInputRef.current.contains(e.target)) setShowRDrop(false);
      if (sugRef.current && !sugRef.current.contains(e.target) && inputRef.current && !inputRef.current.contains(e.target)) setShowSug(false);
    };
    document.addEventListener('mousedown', h);
    return () => document.removeEventListener('mousedown', h);
  }, []);

  // Re-apply localised text when language changes
  useEffect(() => {
    if (!commodity || commodity.tags?.includes('custom')) return;
    const txt = commText[commodity.id] || commText[commodity.id?.replace(/_oil$/,'_oil')];
    if (txt) setCommodity(prev => ({...prev, supplyRoute:txt.supplyRoute, context:txt.context}));
  }, [lang]); // eslint-disable-line

  const stab = seaData.stability;
  const stabClass = stab<0.5?'crit':stab<0.8?'vol':'ok';
  const stabLabel = stab<0.5?t.critical:stab<0.8?t.volatile:t.stable;
  const stabColor = (s) => s>=0.8?'var(--teal)':s>=0.5?'var(--amber)':'var(--dn)';

  const regionSugs = useMemo(() => {
    const q = regionQ.trim().toLowerCase();
    return REGION_NAMES.filter(n => !q || n.toLowerCase().includes(q));
  }, [regionQ]);

  const suggestions = useMemo(() => {
    const q = query.trim().toLowerCase();
    if (!q) return COMMODITIES;
    return COMMODITIES.filter(c => c.name.toLowerCase().includes(q) || c.tags.some(tg=>tg.includes(q)) || c.id.includes(q));
  }, [query]);

  useEffect(() => setHiIdx(-1), [suggestions]);
  useEffect(() => setRegionHi(-1), [regionSugs]);

  const selectRegion = (name) => {
    setLocation(name); setSeaData(REGIONS[name]);
    setRegionQ(''); setShowRDrop(false);
    if (commodity) {
      const r = calcPrice(commodity, REGIONS[name]);
      setLivePrice(r.currentPrice);
      setForecast(calcForecast(commodity, REGIONS[name]));
    }
  };

  const applyCommodity = (comm, sea) => {
    setCommodity(comm);
    const r = calcPrice(comm, sea);
    setLivePrice(r.currentPrice); setPrevPrice(null);
    setNotFound(null); setError(null);
    setForecast(calcForecast(comm, sea));
  };

  const runLookup = useCallback(async (q) => {
    if (!q?.trim()) return;
    setLoading(true); setCommodity(null); setError(null); setNotFound(null); setLivePrice(null); setForecast(null); setShowSug(false);
    const known = COMMODITIES.find(c => c.name.toLowerCase()===q.toLowerCase() || c.name.toLowerCase().includes(q.toLowerCase()) || c.id===q.toLowerCase().replace(/ /g,'_'));
    if (known) {
      const txt = commText[known.id] || { supplyRoute:'', context:'' };
      applyCommodity({...known, supplyRoute:txt.supplyRoute, context:txt.context}, seaData);
      setLoading(false); return;
    }
    try {
      const r = await lookupCustomItem(q, seaData, location);
      if (r.notCommodity) {
        const words = q.toLowerCase().split(' ');
        const sug = COMMODITIES.find(c => words.some(w=>w.length>3&&(c.name.toLowerCase().includes(w)||c.tags.some(tg=>tg.includes(w)))));
        setNotFound({ name:q, suggestion:sug||null });
      } else {
        const comm = { id:q.toLowerCase().replace(/ /g,'_'), name:r.name||q, icon:r.icon||'📦', tags:['custom'], unit:r.unit||'unit', basePrice:r.basePrice||10, sensitivity:r.sensitivity||0.5, routes:r.routes||[], origins:r.origins||[], supplyRoute:r.supplyRoute||'', context:r.context||'' };
        applyCommodity(comm, seaData);
      }
    } catch { setError(t.depthReadFailed); }
    finally { setLoading(false); }
  }, [seaData, location, commText, t]); // eslint-disable-line

  const handleSubmit = (e) => { e.preventDefault(); runLookup(hiIdx>=0&&suggestions[hiIdx]?suggestions[hiIdx].name:query); };
  const handleKD = (e) => {
    if (!showSug||!suggestions.length) return;
    if (e.key==='ArrowDown'){e.preventDefault();setHiIdx(i=>Math.min(i+1,suggestions.length-1));}
    if (e.key==='ArrowUp'){e.preventDefault();setHiIdx(i=>Math.max(i-1,-1));}
    if (e.key==='Escape') setShowSug(false);
  };
  const handleRKD = (e) => {
    if (!showRDrop||!regionSugs.length) return;
    if (e.key==='ArrowDown'){e.preventDefault();setRegionHi(i=>Math.min(i+1,regionSugs.length-1));}
    if (e.key==='ArrowUp'){e.preventDefault();setRegionHi(i=>Math.max(i-1,-1));}
    if (e.key==='Enter'){e.preventDefault();if(regionHi>=0)selectRegion(regionSugs[regionHi]);}
    if (e.key==='Escape') setShowRDrop(false);
  };

  const getImpact = () => {
    const i = {
      en:{ tradeOk:'Routes operating normally.', tradeSwell:'High swells causing shipping delays.', tradeGeo:'Geopolitical factors forcing route rerouting.', secOk:'Standard monitoring in place.', secHigh:'High Alert: Active conflict or port closures nearby.', secCaution:'Caution: Elevated regional tensions reported.', ecoOk:'Ecosystem stable.', ecoWarm:'Warmer waters may shift fish migration patterns.' },
      es:{ tradeOk:'Rutas operando con normalidad.', tradeSwell:'Oleaje elevado causa retrasos en el transporte.', tradeGeo:'Factores geopolíticos fuerzan el desvío de rutas.', secOk:'Vigilancia estándar en curso.', secHigh:'Alerta máxima: conflicto activo o puertos cerrados.', secCaution:'Precaución: Tensiones regionales elevadas.', ecoOk:'Ecosistema estable.', ecoWarm:'Aguas más cálidas pueden alterar la migración marina.' },
      zh:{ tradeOk:'航线运营正常。', tradeSwell:'大浪导致航运延误。', tradeGeo:'地缘政治因素迫使航线改道。', secOk:'标准监控中。', secHigh:'高度警戒：附近有活跃冲突或港口封闭。', secCaution:'注意：地区紧张局势升级。', ecoOk:'生态系统稳定。', ecoWarm:'水温升高可能改变鱼群洄游路线。' },
    }[lang];
    return {
      trade: seaData.waves>3.5 ? i.tradeSwell : stab<0.7 ? i.tradeGeo : i.tradeOk,
      security: stab<0.5 ? i.secHigh : stab<0.8 ? i.secCaution : i.secOk,
      eco: seaData.anomaly>0.5 ? i.ecoWarm : i.ecoOk,
    };
  };
  const impact = getImpact();

  const evType = (type) => ({geopolitical:{en:'geopolitical',es:'geopolítico',zh:'地缘政治'},climate:{en:'climate',es:'climático',zh:'气候'},logistics:{en:'logistics',es:'logístico',zh:'物流'}}[type]?.[lang]||type);
  const evImpact = (imp) => ({Critical:{en:'Critical',es:'Crítico',zh:'危急'},High:{en:'High',es:'Alto',zh:'高'},Medium:{en:'Medium',es:'Medio',zh:'中'}}[imp]?.[lang]||imp);
  const routeStatusLabel = (s) => ({critical:{en:'🔴 Disrupted',es:'🔴 Interrumpida',zh:'🔴 中断'},reduced:{en:'🟡 Restricted',es:'🟡 Restringida',zh:'🟡 受限'},elevated:{en:'🟠 Elevated Risk',es:'🟠 Riesgo Elevado',zh:'🟠 风险升高'},congested:{en:'🟠 Congested',es:'🟠 Congestionada',zh:'🟠 拥堵'},normal:{en:'🟢 Operational',es:'🟢 Operacional',zh:'🟢 正常运营'},seasonal:{en:'🔵 Seasonal',es:'🔵 Estacional',zh:'🔵 季节性'}}[s]?.[lang]||s);

  const isUp = livePrice!==null && commodity ? livePrice>=commodity.basePrice : false;
  const priceColor = isUp ? 'var(--up)' : 'var(--dn)';
  const shiftPct = commodity && livePrice ? ((livePrice-commodity.basePrice)/commodity.basePrice*100) : 0;
  const fmtP = (v) => { if (!v||!commodity) return ''; if (commodity.basePrice>=100) return '$'+v.toFixed(0); if (commodity.basePrice<1) return '$'+v.toFixed(4); return '$'+v.toFixed(2); };
  const predColor = (pred) => { if (!livePrice||!pred) return 'var(--foam2)'; return pred>=livePrice?'var(--up)':'var(--dn)'; };
  const filteredRoutes = routeFilter==='all' ? routes : routes.filter(r=>r.status===routeFilter);

  return (
    <>
      <style>{css}</style>
      <MarineLayer/>

      {showFishing && <FishingGame onClose={() => setShowFishing(false)}/>}

      <nav className="nav">
        <div className="nav-inner">
          <div className="brand" onClick={() => setShowFishing(true)} title="Click to fish the markets!">
            <div className="brand-icon"><Ship size={20} color="#00d4ff"/></div>
            <div className="brand-name">The <span>Current</span></div>
          </div>
          <div className="nav-center">
            <button className={`tab ${tab==='dashboard'?'on':''}`} onClick={()=>setTab('dashboard')}>{t.tabPulse}</button>
            <button className={`tab ${tab==='wallet'?'on':''}`} onClick={()=>setTab('wallet')}>{t.tabPrices}</button>
            <button className={`tab ${tab==='routes'?'on':''}`} onClick={()=>setTab('routes')}>{t.tabRoutes}</button>
          </div>
          <div className="nav-right">
            <div className="lang-switcher">
              {['en','es','zh'].map(l=>(
                <button key={l} className={`lang-btn${lang===l?' active':''}`} onClick={()=>setLang(l)}>
                  {l==='en'?'EN':l==='es'?'ES':'中文'}
                </button>
              ))}
            </div>
            <div className="nav-loc"><MapPin size={10} color="#00d4ff"/>{location}</div>
          </div>
        </div>
      </nav>

      {tab==='dashboard'&&(
        <>
          <div className="page">
            <div className="masthead">
              <div>
                <div className="kicker">{t.kickerDash}</div>
                <h1 className="headline"><span style={{color:'var(--foam2)'}}>{location}</span><br/><em>{t.stabilityReport}</em></h1>
              </div>
              <div className="stab-box">
                <div className={`stab-num ${stabClass}`}>{Math.round(stab*100)}<span style={{fontSize:24,color:'var(--foam2)'}}>%</span></div>
                <div className="stab-lbl">{t.stabilityIndex}</div>
                <div className={`stab-tag ${stabClass}`}>{stabLabel}</div>
              </div>
            </div>
          </div>

          <WaveDivider/>
          <div className="depth-band">
            <div className="depth-inner">
              {[
                {icon:<Thermometer size={13}/>,lbl:t.surfaceTemp, val:seaData.sst.toFixed(1),   unit:'°C',  sub:t.observed,                                                             tipKey:'surfaceTemp'},
                {icon:<Waves       size={13}/>,lbl:t.waveHeight,  val:seaData.waves.toFixed(1), unit:'m',   sub:t.significant,                                                         tipKey:'waveHeight'},
                {icon:<Activity    size={13}/>,lbl:t.climateDelta,val:(seaData.anomaly>0?'+':'')+seaData.anomaly.toFixed(2),unit:'°',sub:seaData.anomaly>0?t.aboveBaseline:t.belowBaseline,tipKey:'climateDelta'},
                {icon:<Wind        size={13}/>,lbl:t.windSpeed,   val:seaData.wind.toFixed(0),   unit:'kts', sub:t.surface,                                                             tipKey:'windSpeed'},
              ].map((s,i)=>(
                <StatCell key={i} icon={s.icon} lbl={s.lbl} val={s.val} unit={s.unit} sub={s.sub} explain={statExplain[s.tipKey]}/>
              ))}
            </div>
          </div>
          <WaveDivider flip/>

          <div className="page" style={{paddingTop:'2rem'}}>
            {alertOpen&&stab<0.5&&(
              <div className="alert">
                <ShieldAlert size={14} color="var(--dn)" style={{marginTop:2,flexShrink:0}}/>
                <div>
                  <div className="alert-title">{t.securityAdvisory}</div>
                  <div className="alert-body">{t.alertBody(location,Math.round((1-stab)*30))}</div>
                </div>
                <button className="alert-close" onClick={()=>setAlertOpen(false)}>×</button>
              </div>
            )}

            <div className="region-wrap">
              <div className="region-form">
                <span className="region-label"><Anchor size={11}/>{t.searchRegion}</span>
                <input ref={regionInputRef} type="text" placeholder={t.filterRegion}
                  value={regionQ} onChange={e=>{setRegionQ(e.target.value);setShowRDrop(true);}}
                  onFocus={()=>setShowRDrop(true)} onKeyDown={handleRKD} autoComplete="off"/>
                {regionQ&&<button type="button" className="region-clear" onClick={()=>{setRegionQ('');regionInputRef.current?.focus();}}><X size={12}/></button>}
                <button className="region-btn" onClick={()=>{if(regionSugs.length>0)selectRegion(regionHi>=0?regionSugs[regionHi]:regionSugs[0]);}}>{t.selectBtn}</button>
              </div>
              {showRDrop&&regionSugs.length>0&&(
                <div className="region-dropdown" ref={regionDropRef}>
                  {regionSugs.map((name,i)=>{
                    const r=REGIONS[name];
                    const sl=r.stability>=0.8?t.stable:r.stability>=0.5?t.volatile:t.critical;
                    return(
                      <div key={name} className={`region-option${i===regionHi?' hi':''}`} onMouseDown={()=>selectRegion(name)}>
                        <span className="region-opt-name">{name}</span>
                        <span className="region-opt-stab" style={{color:stabColor(r.stability)}}>{sl} · {Math.round(r.stability*100)}%</span>
                      </div>
                    );
                  })}
                </div>
              )}
            </div>

            <div className="cols">
              <div>
                <div className="sh"><span className="sh-lbl">{t.worldEvents}</span><div className="sh-rule"/></div>
                {events.map((ev,i)=>(
                  <div className="event" key={ev.id}>
                    <div className="ev-num">{String(i+1).padStart(2,'0')}</div>
                    <div>
                      <div className="ev-meta">
                        <span className="ev-type">{evType(ev.type)}</span>
                        <span style={{color:'var(--rule2)',fontSize:10}}>·</span>
                        <span className="ev-loc">{ev.location}</span>
                      </div>
                      <div className="ev-title">{ev.title}</div>
                      <div className="ev-desc">{ev.description}</div>
                    </div>
                    <div className={`badge ${ev.impact==='Critical'?'crit':ev.impact==='High'?'high':'med'}`}>{evImpact(ev.impact)}</div>
                  </div>
                ))}
              </div>
              <div className="sidebar">
                <div>
                  <div className="sh"><span className="sh-lbl">{t.routeViability}</span><div className="sh-rule"/></div>
                  <div className="panel">
                    <div className="panel-head"><span className="panel-title">{t.activeCorridor}</span><Anchor size={12} color="var(--bio3)"/></div>
                    <div className="panel-row"><span className="panel-lbl">{t.capeDiversion}</span><span className="panel-val val-dn">{t.capeVal}</span></div>
                    <div className="panel-row"><span className="panel-lbl">{t.panamaLimits}</span><span className="panel-val val-amber">{t.panamaVal}</span></div>
                    <div className="panel-row"><span className="panel-lbl">{t.arcticNSR}</span><span className="panel-val val-teal">{t.arcticVal}</span></div>
                    <button className="panel-cta" onClick={()=>setTab('wallet')}>{t.checkPriceBtn}</button>
                  </div>
                </div>
                <div>
                  <div className="sh"><span className="sh-lbl">{t.integratedRisk}</span><div className="sh-rule"/></div>
                  <div className="panel">
                    <div className="risk-block"><div className="risk-lbl">{t.tradeFlow}</div><div className="risk-txt">{impact.trade}</div></div>
                    <div className="risk-block"><div className="risk-lbl">{t.globalSec}</div><div className="risk-txt">{impact.security}</div></div>
                    <div className="risk-block"><div className="risk-lbl">{t.ecosystem}</div><div className="risk-txt">{impact.eco}</div></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </>
      )}

      {tab==='wallet'&&(
        <div className="page">
          <div className="masthead" style={{gridTemplateColumns:'1fr',gap:'0.5rem',marginBottom:'2rem'}}>
            <div className="kicker">{t.kickerWallet} · {location}</div>
            <h1 className="headline" style={{fontSize:'clamp(32px,4vw,48px)'}}>{t.walletTitle} <em>{t.walletTitleEm}</em></h1>
          </div>
          <div className="sh"><span className="sh-lbl">{t.lookupSh}</span><div className="sh-rule"/></div>
          <div className="ocean-badge"><div className="pulse-dot"/>{t.badgeTxt(COMMODITIES.length)}</div>
          <div className="search-wrap" style={{marginBottom:'1.25rem'}}>
            <form className="search-row" onSubmit={handleSubmit}>
              <input ref={inputRef} type="text" placeholder={t.searchPlaceholder(COMMODITIES.length)}
                value={query} onChange={e=>{setQuery(e.target.value);setShowSug(true);}}
                onFocus={()=>setShowSug(true)} onKeyDown={handleKD} autoComplete="off"/>
              {query&&<button type="button" className="search-clear" onClick={()=>{setQuery('');setCommodity(null);setError(null);setNotFound(null);setLivePrice(null);setForecast(null);inputRef.current?.focus();}}><X size={13}/></button>}
              <button type="submit" className="search-go" disabled={loading}>
                {loading?<div style={{width:7,height:7,borderRadius:'50%',background:'var(--bio)',boxShadow:'0 0 6px var(--bio)'}}/>:<><Search size={13}/>{t.searchLabel}</>}
              </button>
            </form>
            {showSug&&suggestions.length>0&&(
              <div className="suggestions" ref={sugRef}>
                {suggestions.slice(0,12).map((c,i)=>(
                  <div key={c.id} className={`suggestion${i===hiIdx?' hi':''}`} onMouseDown={()=>{setQuery(c.name);setShowSug(false);runLookup(c.name);}}>
                    <span className="sug-icon">{c.icon}</span>
                    <div><div className="sug-name">{c.name}</div><div className="sug-tags">{c.tags.join(' · ')}</div></div>
                  </div>
                ))}
                {suggestions.length>12&&<div style={{padding:'7px 13px',fontSize:8.5,color:'var(--foam3)',textAlign:'center',letterSpacing:'0.10em',textTransform:'uppercase'}}>{t.moreSuggestions(suggestions.length-12)}</div>}
              </div>
            )}
          </div>
          {loading&&(<div className="sonar-wrap"><div className="sonar"><div className="sonar-ring"/><div className="sonar-ring"/><div className="sonar-ring"/><div className="sonar-center"/></div><div className="sonar-txt">{t.scanning}</div></div>)}
          {notFound&&!loading&&(
            <div className="unknown-card">
              <div className="unknown-card-title"><AlertCircle size={16} color="var(--bio)"/>{t.notFoundTitle(notFound.name)}</div>
              <div className="unknown-card-body">{t.notFoundBody}</div>
              <div className="unknown-card-hint">
                {t.notFoundHint(notFound.suggestion)}
                {notFound.suggestion&&<span style={{color:'var(--bio)',cursor:'pointer',textDecoration:'underline'}} onClick={()=>{setQuery(notFound.suggestion.name);runLookup(notFound.suggestion.name);setNotFound(null);}}>{notFound.suggestion.name}</span>}
              </div>
            </div>
          )}
          {error&&!loading&&(<div className="err-card"><AlertCircle size={13} color="var(--dn)" style={{flexShrink:0,marginTop:1}}/><div>{error}</div></div>)}
          {commodity&&livePrice!==null&&!loading&&(
            <div className="result-card">
              <div className="price-header">
                <div className="price-top-row">
                  <div className="price-meta">
                    <div className="price-name">{commodity.icon} {commodity.name}</div>
                    <div className="price-base">{t.usBaseline}: {fmtP(commodity.basePrice)} / {commodity.unit}</div>
                  </div>
                </div>
                <div className="prices-cols">
                  <div className="price-col">
                    <div className="price-col-label" style={{color:'var(--bio)'}}><div className="live-dot"/>{t.livePrice}</div>
                    <div className={`price-big ${flashClass}`} style={{color:priceColor}}>{fmtP(livePrice)}</div>
                    <div className="price-shift" style={{color:priceColor}}>
                      {isUp?<TrendingUp size={11}/>:<TrendingDown size={11}/>}
                      {isUp?'+':''}{shiftPct.toFixed(2)}% {t.vsBaseline}
                    </div>
                  </div>
                  {forecast&&(
                    <div className="price-col">
                      <div className="predicted-label"><span style={{fontSize:10,opacity:0.7}}>◈</span>{t.predictedPrice}</div>
                      <div className="predicted-big" style={{color:predColor(forecast.sixMonth)}}>{fmtP(forecast.sixMonth)}</div>
                      <div className="predicted-sub">{t.predictedSub}</div>
                      <div className="pred-range">{t.threeMonth}: {fmtP(forecast.threeMonth)}</div>
                    </div>
                  )}
                </div>
              </div>
              <div className="result-notes">
                <div><span className="note-lbl">{t.supplyChain}</span><div className="note-txt">{commodity.supplyRoute}</div></div>
                <div><span className="note-lbl">{t.usMarket}</span><div className="note-txt">{commodity.context}</div></div>
              </div>
              {commodity.origins?.length>0&&(<div className="origin-row"><span className="origin-lbl">{t.origins}</span>{commodity.origins.map(o=><span key={o} className="origin-tag">{o}</span>)}</div>)}
              {commodity.routes?.length>0&&(<div className="origin-row"><span className="origin-lbl">{t.keyRoutes}</span>{commodity.routes.map(r=><span key={r} className="origin-tag" style={{cursor:'pointer'}} onClick={()=>setTab('routes')}>{r}</span>)}</div>)}
              <div className="sens-row">
                <span className="sens-lbl">{t.maritimeSens}</span>
                <div className="sens-track"><div className="sens-fill" style={{width:`${(commodity.sensitivity||0)*100}%`}}/></div>
                <span className="sens-pct">{Math.round((commodity.sensitivity||0)*100)}%</span>
              </div>
            </div>
          )}
        </div>
      )}

      {tab==='routes'&&(
        <div className="page">
          <div className="masthead" style={{gridTemplateColumns:'1fr',gap:'0.5rem',marginBottom:'2rem'}}>
            <div className="kicker">{t.routeGlobalKicker}</div>
            <h1 className="headline" style={{fontSize:'clamp(32px,4vw,48px)'}}><em>{t.routeTitle}</em></h1>
          </div>
          <div className="sh"><span className="sh-lbl">{t.routeStatusFilter}</span><div className="sh-rule"/></div>
          <div className="routes-filter">
            {[{key:'all',lbl:t.allRoutes},{key:'critical',lbl:t.disrupted},{key:'reduced',lbl:t.restricted},{key:'elevated',lbl:t.elevatedRisk},{key:'congested',lbl:t.congested},{key:'normal',lbl:t.operational}].map(f=>(
              <button key={f.key} className={`filter-btn${routeFilter===f.key?' active':''}`} onClick={()=>setRouteFilter(f.key)}>{f.lbl}</button>
            ))}
          </div>
          <div className="routes-grid">
            {filteredRoutes.map(route=>{
              const sc=ROUTE_STATUS_COLORS[route.status]||ROUTE_STATUS_COLORS.normal;
              const affComms=COMMODITIES.filter(c=>route.affected.includes(c.id));
              return(
                <div key={route.id} className="route-card" style={{borderColor:sc.border,background:sc.bg}}>
                  <div className="route-card-top">
                    <div className="route-icon-col">
                      <div className="route-icon">{route.icon}</div>
                      <div className="route-status-badge" style={{borderColor:sc.border,color:sc.color}}>{routeStatusLabel(route.status)}</div>
                    </div>
                    <div>
                      <div className="route-header-row">
                        <div className="route-name">{route.name}</div>
                        <div className="route-delay-box">
                          <div className="route-delay-val" style={{color:sc.color}}>{route.delay}</div>
                          <div className="route-delay-lbl">{t.impact}</div>
                        </div>
                      </div>
                      <div className="route-meta">
                        <div className="route-meta-item"><span className="route-meta-label">{t.transit}</span>{route.transit}</div>
                        <div className="route-meta-item"><span className="route-meta-label">{t.volume}</span>{route.throughput}</div>
                        <div className="route-meta-item"><span className="route-meta-label">{t.region}</span>{route.region}</div>
                      </div>
                      <div className="route-desc">{route.description}</div>
                    </div>
                  </div>
                  {affComms.length>0&&(
                    <div className="route-card-bottom">
                      <div className="route-affected-label">{t.affectedComm}</div>
                      <div className="route-affected-list">
                        {affComms.map(c=><span key={c.id} className="affected-tag" onClick={()=>{setQuery(c.name);setTab('wallet');runLookup(c.name);}}>{c.icon} {c.name}</span>)}
                      </div>
                    </div>
                  )}
                  {route.alternatives?.length>0&&(
                    <div className="route-alt-section">
                      <div className="route-alt-label">{t.altRouting}</div>
                      {route.alternatives.map((alt,i)=><div key={i} className="route-alt-item">{alt}</div>)}
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      )}

      <div className="footer-outer">
        <div className="footer">
          <div>
            <div className="footer-brand">{t.footerBrand}</div>
            <div className="footer-desc">{t.footerDesc(COMMODITIES.length)}</div>
          </div>
          <div>
            <div className="footer-src-title">{t.footerSrcTitle}</div>
            {[['NOAA Coral Reef Watch','Daily Global 5km SST Anomaly (v3.1)'],['Council on Foreign Relations','Global Conflict Tracker & Maritime Security'],['Copernicus Marine Service','Global Ocean Waves Analysis (WAM Model)'],['IMF & World Bank','Commodity Sensitivity & Logistics Indexing'],['UNCTAD','Review of Maritime Transport & Port Reliability']].map(([n,d])=>(
              <div className="footer-src" key={n}><div className="footer-src-name">{n}</div><div className="footer-src-detail">{d}</div></div>
            ))}
          </div>
        </div>
        <div className="footer-bar"><span>© 2026 The Current Logistics Protocols</span><span>{t.footerBar(COMMODITIES.length)}</span></div>
      </div>
    </>
  );
}
