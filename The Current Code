// ─── Price engine ─────────────────────────────────────────────────────────────
function calcPrice(commodity, sea, noiseOffset = 0) {
  const c = 1 + (sea.anomaly * commodity.sensitivity * 0.10);
  const s = 1 + ((1 - sea.stability) * commodity.sensitivity * 0.22);
  const w = 1 + (Math.max(0, sea.waves - 2.5) * commodity.sensitivity * 0.04);
  const noise = 1 + noiseOffset * commodity.sensitivity * 0.004;
  const currentPrice = commodity.basePrice * c * s * w * noise;
  return { ...commodity, currentPrice, priceShift: currentPrice - commodity.basePrice, shiftPercent: ((currentPrice - commodity.basePrice) / commodity.basePrice) * 100 };
}

function calcForecast(commodity, sea) {
  const base = commodity.basePrice;
  const current = calcPrice(commodity, sea).currentPrice;
  const persistence = 1 - sea.stability * 0.3;
  const shift = (current - base) / base;
  let fp = current;
  const months = [];
  for (let i = 1; i <= 6; i++) {
    fp = Math.max(base * 0.55, fp + (base - fp) * 0.12 * (1 - persistence * 0.5) + fp * shift * 0.02 * persistence + (Math.random() - 0.48) * base * 0.022);
    months.push(fp);
  }
  return { threeMonth: months[2], sixMonth: months[5] };
}

async function lookupCustomItem(query, sea, loc) {
  const prompt = `US commodity pricing analyst. Respond ONLY with raw JSON, no markdown, no preamble.
Item: "${query}"
Maritime: ${loc} | Stability ${Math.round(sea.stability*100)}% | SST ${sea.anomaly>0?'+':''}${sea.anomaly.toFixed(2)}°C | Waves ${sea.waves.toFixed(1)}m
{"name":"","icon":"","unit":"","basePrice":0,"sensitivity":0,"supplyRoute":"1-2 sentences on maritime supply chain impact.","context":"1 sentence on US market context.","origins":[""],"routes":[""]}
If NOT a real ocean-shipped commodity return only: {"notCommodity":true}
Use accurate early-2026 US market prices.`;
  const r = await fetch('https://api.anthropic.com/v1/messages', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ model:'claude-haiku-4-5-20251001', max_tokens:350, messages:[{role:'user',content:prompt}] }),
  });
  if (!r.ok) throw new Error(`HTTP ${r.status}`);
  const d = await r.json();
  if (d.error) throw new Error(d.error.message);
  const txt = d.content?.find(b=>b.type==='text')?.text || '';
  return JSON.parse(txt.replace(/```json|```/gi,'').trim());
}

