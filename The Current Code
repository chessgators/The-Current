const RARITY = {
  common:   { label:'Common',   weight:55, glow:null,                                 color:'#a8ccd8', border:'rgba(168,204,216,0.3)' },
  uncommon: { label:'Uncommon', weight:28, glow:'0 0 18px 4px rgba(34,197,94,0.55)', color:'#22c55e', border:'rgba(34,197,94,0.5)' },
  rare:     { label:'Rare',     weight:13, glow:'0 0 22px 5px rgba(59,130,246,0.65)',color:'#3b82f6', border:'rgba(59,130,246,0.55)' },
  epic:     { label:'Epic',     weight:4,  glow:'0 0 26px 7px rgba(139,92,246,0.70)',color:'#8b5cf6', border:'rgba(139,92,246,0.6)' },
};

function pickItem() {
  const pool = [];
  FISH_ITEMS.forEach(item => { for (let i = 0; i < RARITY[item.rarity].weight; i++) pool.push(item); });
  return pool[Math.floor(Math.random() * pool.length)];
}

function fmtFishPrice(p, unit) {
  const v = p < 1 ? '$'+p.toFixed(4) : p < 100 ? '$'+p.toFixed(2) : '$'+Math.round(p).toLocaleString();
  return `${v} / ${unit}`;
}

