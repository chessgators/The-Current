// ─── StatCell with hover tooltip ──────────────────────────────────────────────
function StatCell({ icon, lbl, val, unit, sub, explain }) {
  const [open, setOpen] = useState(false);
  const ref = useRef(null);
  useEffect(() => {
    if (!open) return;
    const h = (e) => { if (ref.current && !ref.current.contains(e.target)) setOpen(false); };
    document.addEventListener('mousedown', h);
    return () => document.removeEventListener('mousedown', h);
  }, [open]);
  return (
    <div className="depth-stat" ref={ref} style={{position:'relative'}}>
      <div className="depth-icon">{icon}</div>
      <div style={{display:'flex',alignItems:'center',gap:5}}>
        <div className="depth-lbl">{lbl}</div>
        <button onClick={()=>setOpen(o=>!o)} title="Why does this matter?"
          style={{background:'none',border:'none',cursor:'pointer',padding:0,display:'flex',alignItems:'center',color:open?'var(--bio)':'var(--foam3)',transition:'color 0.15s'}}>
          <Info size={10}/>
        </button>
      </div>
      <div className="depth-val">{val}<span className="depth-unit">{unit}</span></div>
      <div className="depth-sub">{sub}</div>
      {open && explain && (
        <div style={{position:'absolute',top:'calc(100% + 6px)',left:0,zIndex:80,width:260,background:'var(--deep)',border:'1px solid var(--rule2)',padding:'12px 14px',boxShadow:'0 8px 32px rgba(0,0,0,0.7)',animation:'fade-up 0.18s ease'}}>
          <div style={{position:'absolute',top:-5,left:14,width:8,height:8,background:'var(--deep)',border:'1px solid var(--rule2)',transform:'rotate(45deg)',borderBottom:'none',borderRight:'none'}}/>
          <div style={{fontSize:7.5,letterSpacing:'0.22em',textTransform:'uppercase',color:'var(--bio)',marginBottom:7,fontFamily:'var(--sans)'}}>{explain.why}</div>
          <div style={{fontSize:10.5,color:'var(--foam2)',lineHeight:1.65,fontFamily:'var(--sans)'}}>{explain.body}</div>
        </div>
      )}
    </div>
  );
}

